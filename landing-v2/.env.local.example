# Copy to .env.local and fill in. Not required for the form to RENDER, but
# without LEAD_WEBHOOK_URL leads are only logged to the server console (not
# delivered). See LEAD_FORM_SETUP.md for step-by-step.

# --- Lead delivery (Google Apps Script web app: logs to Sheet + emails) ---
LEAD_WEBHOOK_URL=

# --- Google Ads conversion (fires on successful submit; optional) ---
NEXT_PUBLIC_GADS_ID=AW-XXXXXXXXXX                       # the Google Ads tag id
NEXT_PUBLIC_GADS_CONVERSION=AW-XXXXXXXXXX/yyyyyyyyyyyyy # the "Submit Lead Form" conversion send-to (id/label)
